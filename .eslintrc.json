{
  "env": {
    "browser": true,
    "es2021": true,
    "node": true
  },
  "extends": [
    "eslint:recommended"
  ],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "indent": ["error", 2],
    "linebreak-style": ["error", "unix"],
    "quotes": ["error", "single"],
    "semi": ["error", "always"]
  },
  "overrides": [
    {
      "files": ["*.html"],
      "parser": "html-eslint-parser",
      "plugins": ["html"],
      "rules": {
        "no-unused-vars": "off",
        "no-undef": "off"
      },
      "settings": {
        "html/html-extensions": [".html"],
        "html/report-bad-indent": "error",
        "html/javascript-mime-types": ["text/javascript", "application/javascript"]
      }
    }
  ],
  "ignorePatterns": [
    "**/*.html"
  ]
}